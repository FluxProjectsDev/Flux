*.zip
obj/
libs/
.idea/
.vscode/

# Release/proof artifacts generated by the CI scripts (gen_release_metadata.sh,
# verify-*-inventory.sh, verify-native-hardening.sh). They are produced into the workspace during
# a build and uploaded as CI artifacts; they are never committed. Listed so a local run of those
# scripts cannot accidentally stage them.
SHA256SUMS
build-metadata.json
package-inventory.tsv
webui-inventory.tsv
native-hardening-*.exports

# Host test suite output (jni/tests/run_tests.sh)
jni/tests/build/

# Maintainer-supplied approved branding sources.
#
# The approved banner/logo artwork is supplied out of band and converted into the packaged assets
# under module/assets/. The originals are large, are not the project's to redistribute from here,
# and must never reach the module ZIP — so they stay untracked rather than living in the tree.
# scripts/verify-branding.py deliberately validates the committed conversion instead of these,
# because CI has no access to them.
.user-assets/

# Python bytecode. Three .pyc files were committed by accident, including stale bytecode for a
# generator this branch deleted — they are build output of scripts/, never inputs, and nothing
# reads them.
__pycache__/
*.pyc
